#: po/joerc.for-po:663
msgid ""
"  \\uMATH "
"COMMANDS\\u                                                               "
"\\| \n"
"  Statistics on region of numbers  Linear regression on region of x y "
"pairs   \\| \n"
"  \\bsum\\b  Sum                         \\blr(x)\\b  Estimate y given x     "
"y=m*x+b      \\| \n"
"  \\bcnt\\b  Count                       \\brlr(y)\\b Estimate x given "
"y                  \\| \n"
"  \\bavg\\b  Mean                        \\bLr rLr\\b Logarithmic regression "
"y=m*ln(x)+b  \\| \n"
"    Standard deviation:            \\blR rlR\\b Exponential regression "
"y=e^(m*x)+b  \\| \n"
"  \\bdev\\b  all data present            \\bLR rLR\\b Power regression       "
"y=b*x^m      \\| \n"
"  \\bsamp\\b sample of data present      Side effects: \\bb\\b, \\bm\\b: "
"regression coef.       \\| \n"
"                                       \\br\\b: correlation coef., "
"\\bcov\\b: covariance  \\| \n"
msgstr ""

#: po/joerc.for-po:675
msgid ""
"  Hit TAB to complete names.  Use up / down arrow keys to traverse "
"history.   \\| \n"
"  Special file "
"names:                                                         \\| \n"
"       \\b!\\bcommand                 Pipe in/out of a shell "
"command                \\| \n"
"       \\b>>\\bfilename               Append to a "
"file                              \\| \n"
"       \\b-\\b                        Read/Write to/from standard I/"
"O               \\|\n"
"       filename\\b,START,SIZE\\b      Read/Write a part of a file/"
"device            \\| \n"
"           Give START/SIZE in decimal (255), octal (0377) or hex "
"(0xFF)       \\| \n"
"       \\b\\\\,\\b                       Use backslash to quote special "
"characters     \\|\n"
" \\b^C\\b    to abort\n"
msgstr ""

